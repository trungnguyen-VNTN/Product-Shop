    </servlet>
    <servlet>
        <servlet-name>AccountToggleStatusController</servlet-name>
        <servlet-class>controller.account.AccountToggleStatusController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AccountUpdateViewController</servlet-name>
        <servlet-class>controller.account.AccountUpdateViewController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CategoryListController</servlet-name>
        <servlet-class>controller.category.CategoryListController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CategoryAddController</servlet-name>
        <servlet-class>controller.category.CategoryAddController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CategoryUpdateViewController</servlet-name>
        <servlet-class>controller.category.CategoryUpdateViewController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CategoryUpdateController</servlet-name>
        <servlet-class>controller.category.CategoryUpdateController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CategoryDeleteController</servlet-name>
        <servlet-class>controller.category.CategoryDeleteController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProductListController</servlet-name>
        <servlet-class>controller.product.ProductListController</servlet-class>
    </servlet>
