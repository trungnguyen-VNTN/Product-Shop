        <servlet-name>ProductAddController</servlet-name>
        <servlet-class>controller.product.ProductAddController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProductAddViewController</servlet-name>
        <servlet-class>controller.product.ProductAddViewController</servlet-class>
    </servlet>
