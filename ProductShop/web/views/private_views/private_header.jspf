<%@page contentType="text/html" pageEncoding="UTF-8"%>
<link rel="stylesheet" href="${pageContext.request.contextPath}/css/private_css/private_header.css">

<div class="admin-header">

    <div class="header-left">
        <div class="welcome-box">
            Welcome to 
            <span class="role">${sessionScope.user.account}</span>
            [
            <span class="fullname">
                ${sessionScope.user.lastName} ${sessionScope.user.firstName}
            </span>
            ]
        </div>
    </div>

    <div class="header-center">
        <a href="main_controller?action=home" class="nav-item">Home</a>
        <a href="main_controller?action=private" class="nav-item">Dashboard</a>
        <a href="main_controller?action=private_accounts" class="nav-item">Accounts</a>
        <a href="main_controller?action=private_products" class="nav-item">Products</a>
        <a href="main_controller?action=private_categories" class="nav-item">Categories</a>
    </div>

    <div class="header-right">
        <a href="main_controller?action=logout" class="logout-btn">Logout</a>
    </div>

</div>